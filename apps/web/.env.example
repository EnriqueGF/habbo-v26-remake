APP_NAME=Habbo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8090

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MariaDB existente (v26). Charset latin1 mientras conviva con el legacy
# (migración a utf8mb4 en la Fase 4).
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=v26
DB_USERNAME=habbo
DB_PASSWORD=habbo
DB_CHARSET=latin1
DB_COLLATION=latin1_general_ci

# El legacy usa sesiones PHP nativas; la BD v26 no tiene tablas sessions/cache.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# Ruta (relativa a la raíz de la app) del legacy HoloCMS servido in-process.
LEGACY_PATH=legacy

# MUS / emulador.
EMU_MUS_HOST=emu
EMU_MUS_PORT=30000

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
